<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+: splash API shows the round icon; windowBackground stays plain blue to avoid duplicate logo -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_blue</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_hands</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#FFFFFF</item>
    </style>
</resources>
